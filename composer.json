{
    "name": "inerba/filament-flexy-seo",
    "description": "Flexible FilamentPHP plugin for SEO via a single JSON field, no extra tables, easy to use, fully adaptable.",
    "keywords": [
        "inerba",
        "laravel",
        "filamentphp",
        "seo",
        "filament-flexy-seo"
    ],
    "homepage": "https://github.com/inerba/filament-flexy-seo",
    "support": {
        "issues": "https://github.com/inerba/filament-flexy-seo/issues",
        "source": "https://github.com/inerba/filament-flexy-seo"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Francesco Apruzzese",
            "email": "inerba@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0|^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "pestphp/pest": "^4.0",
        "orchestra/testbench": "^10.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "files": [
            "src/helpers.php"
        ],
        "psr-4": {
            "Inerba\\Seo\\": "src/",
            "Inerba\\Seo\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Inerba\\Seo\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Inerba\\Seo\\SeoServiceProvider"
            ],
            "aliases": {
                "SeoFields": "Inerba\\Seo\\Facades\\SeoFields",
                "SocialFields": "Inerba\\Seo\\Facades\\SocialFields",
                "MetaSection": "Inerba\\Seo\\Facades\\MetaSection"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
