{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "inerba/completissimo",
    "version": "0.1.12",
    "type": "project",
    "description": "CMS built with Laravel 4 & Filament 12",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "abdulmajeed-jamaan/filament-translatable-tabs": "~5.0",
        "achyutn/filament-log-viewer": "~2.0",
        "awcodes/filament-quick-create": "~5.0",
        "awcodes/matinee": "~3.0",
        "awcodes/overlook": "~4.0",
        "awcodes/shout": "~4.0",
        "awssat/laravel-visits": "^6.2",
        "bezhansalleh/filament-shield": "~4.0",
        "codewithdennis/filament-simple-alert": "~4.0",
        "enshrined/svg-sanitize": "^0.22.0",
        "filament/filament": "~5.0",
        "filament/spatie-laravel-media-library-plugin": "~5.0",
        "inerba/filament-db-config": "~1.0",
        "inerba/filament-flexy-seo": "*",
        "laravel/cashier": "^16.0",
        "laravel/fortify": "^1.31",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.10.1",
        "livewire/livewire": "~4.0",
        "mcamara/laravel-localization": "^2.3",
        "mdobes/rich-editor-fullscreen": "~1.0",
        "pboivin/filament-peek": "~4.0",
        "solution-forest/filament-tree": "~4.0",
        "spatie/laravel-sitemap": "^7.3",
        "spatie/laravel-translatable": "^6.11",
        "stechstudio/filament-impersonate": "~4.0",
        "symfony/dom-crawler": "^7.3",
        "tonegabes/filament-phosphor-icons": "~1.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.16",
        "fakerphp/faker": "^1.23",
        "filament/upgrade": "~5.0",
        "larastan/larastan": "^3.7",
        "laravel-lang/lang": "^15.26",
        "laravel/boost": "^2.1",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.1",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"npm run dev\" --names='server,queue,vite'"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "devopt": [
            "@php artisan optimize:clear",
            "@php artisan icons:cache"
        ],
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build",
            "@php artisan db:seed --force",
            "@php artisan storage:link --force",
            "@php artisan shield:super --panel=admin"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/inerba/filament-flexy-seo"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
